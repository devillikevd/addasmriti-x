# API URLs
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8002
NEXT_PUBLIC_MEMORY_SERVICE_URL=http://localhost:8001

# AI Services
OPENAI_API_KEY=sk-xxx
ELEVENLABS_API_KEY=xxx
PINECONE_API_KEY=xxx
PINECONE_ENVIRONMENT=us-east-1

# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-change-in-production
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx

# Storage (AWS S3 or compatible)
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=ap-south-1
AWS_S3_BUCKET=addasmriti-media
NEXT_PUBLIC_CDN_URL=https://cdn.addasmriti.com

# Database
DATABASE_URL=postgresql://addasmriti:password@localhost:5432/addasmriti
REDIS_URL=redis://localhost:6379

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_MIXPANEL_TOKEN=xxx

# Feature Flags
NEXT_PUBLIC_ENABLE_AR=true
NEXT_PUBLIC_ENABLE_VR=false
NEXT_PUBLIC_ENABLE_BLOCKCHAIN=false
NEXT_PUBLIC_ENABLE_VOICE_CLONE=true
